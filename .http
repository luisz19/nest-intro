@baseUrl = http://localhost:3000

@contentType = application/json

GET {{baseUrl}}

### GET Tasks
GET {{baseUrl}}/tasks

### GET one task
GET {{baseUrl}}/tasks/{{taskId}}

### POST task
# @name createTask
POST {{baseUrl}}/tasks
Content-Type: {{contentType}}

{
    "title": "Nest Task",
    "description": "some description",
    "status": "OPEN",
    "userId": "f25a781e-f440-46ec-9196-2a72a97fde08"
}

### Set the task id
@taskId = {{ createTask.response.body.id }}

### POST task incorrect
POST {{baseUrl}}/tasks
Content-Type: {{contentType}}

{
    "title": 2,
    "description": "some description",
    "status": "XXX"
}

### PATCH task status
PATCH {{baseUrl}}/tasks/{{taskId}}
Content-Type: {{contentType}}

{
    "status": "DONE"
}

### DELETE task
DELETE {{baseUrl}}/tasks/{{taskId}}
