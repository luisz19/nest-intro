@baseUrl = http://localhost:3000

@contentType = application/json

### GET Tasks
GET {{baseUrl}}/tasks

### GET one task
GET {{baseUrl}}/tasks/e5a0a96e-25f4-433c-ad55-19a6c9534f88

### POST task
POST {{baseUrl}}/tasks
Content-Type: {{contentType}}

{
    "title": "Nest Task",
    "description": "some description",
    "status": "OPEN"
}

### POST task incorrect
POST {{baseUrl}}/tasks
Content-Type: {{contentType}}

{
    "title": 2,
    "description": "some description",
    "status": "XXX"
}

### PATCH task status
PATCH {{baseUrl}}/tasks/e5a0a96e-25f4-433c-ad55-19a6c9534f88/status
Content-Type: {{contentType}}

{
    "status": "DONE"
}

### DELETE task
DELETE {{baseUrl}}/tasks/b9d352c2-2fa4-4370-8687-c46fa635dc1b
